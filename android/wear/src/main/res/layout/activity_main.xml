<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#0B1740"
    android:padding="12dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hearo Alert"
        android:textColor="#00A8E1"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center"
        android:text="Active — alerts you for critical sounds detected on your phone."
        android:textColor="#C8D4FF"
        android:textSize="11sp" />

    <Button
        android:id="@+id/test_btn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="#FFE600"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:text="Test vibration"
        android:textColor="#0B1740"
        android:textStyle="bold" />
</LinearLayout>
